{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task_id",
    "node_id",
    "branch_name",
    "commit_hash",
    "changed_files",
    "scope_check",
    "forbidden_scope_check",
    "verify_status",
    "review_openrouter",
    "review_google",
    "details_ref",
    "next_action_for_codex",
    "execution_provenance"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "node_id": { "type": "string" },
    "branch_name": { "type": "string" },
    "commit_hash": { "type": "string" },
    "changed_files": { "type": "array", "items": { "type": "string" } },
    "scope_check": { "enum": ["pass", "fail"] },
    "forbidden_scope_check": { "enum": ["pass", "fail"] },
    "verify_status": { "enum": ["pass", "fail", "environment_dependency_missing"] },
    "review_openrouter": { "type": "object" },
    "review_google": { "type": "object" },
    "details_ref": { "type": "object" },
    "next_action_for_codex": { "enum": ["accept", "request_repair", "split_task", "inspect_detail", "open_pr"] },
    "execution_provenance": {
      "type": "object",
      "required": [
        "planner",
        "implementation_owner",
        "implementation_model",
        "implementation_model_provider",
        "codex_wrote_code",
        "verify_layer",
        "review_report_model",
        "review_second_opinion_model"
      ],
      "properties": {
        "planner": { "const": "codex", "type": "string" },
        "implementation_owner": { "const": "opencode_build_local", "type": "string" },
        "implementation_model": { "type": "string" },
        "implementation_model_provider": { "const": "local", "type": "string" },
        "codex_wrote_code": { "const": false, "type": "boolean" },
        "verify_layer": { "const": "verify_local", "type": "string" },
        "review_report_model": { "const": "OpenRouter GPT OSS 120B", "type": "string" },
        "review_second_opinion_model": {
          "type": ["string", "null"],
          "enum": ["Google AI Studio Gemma 4 31B", null]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
